{
  "permissions": {
    "allow": [
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(docker compose:*)",
      "Bash(docker build:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(npm run:*)",
      "Bash(npm ci)",
      "Bash(npm install:*)",
      "Bash(npm audit:*)",
      "Bash(npx vitest:*)",
      "Bash(npx playwright:*)",
      "Bash(npx next:*)",
      "Bash(npx tsc:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl logs:*)",
      "Bash(helm template:*)",
      "Bash(aws ecr:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(aws iam:*)"
    ]
  },
  "env": {
    "POWERSHELL_TELEMETRY_OPTOUT": "1",
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "pwsh -NoProfile -File .claude/hooks/format-node.ps1" }
        ]
      }
    ]
  }
}
